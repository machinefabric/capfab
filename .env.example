# MachineFabric Admin Security Configuration
# Copy this file to .env for local development
# Set these as environment variables in Netlify for production

# JWT Secret - Generate a secure random string for production
# You can generate one with: node -e "console.log(require('crypto').randomBytes(64).toString('hex'))"
JWT_SECRET=REPLACE_WITH_GENERATED_SECRET

# Admin Password - Change this to a secure password
ADMIN_PASSWORD=REPLACE_WITH_SECURE_PASSWORD

# Netlify configuration (these should already be set in netlify.toml)
NETLIFY_SITE_ID=your-site-id
NETLIFY_TOKEN=your-netlify-token