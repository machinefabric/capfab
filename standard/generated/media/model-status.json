{
  "urn": "media:model-status;textable;record",
  "media_type": "application/json",
  "title": "Model Status",
  "profile_uri": "https://capdag.com/schema/model-status",
  "description": "Detailed model status including state, download progress, and health information",
  "schema": {
    "type": "object",
    "required": [
      "state"
    ],
    "properties": {
      "state": {
        "type": "string",
        "enum": [
          "not_found",
          "available",
          "downloading",
          "paused",
          "ready",
          "failed"
        ],
        "description": "Current state of the model"
      },
      "total_bytes": {
        "type": "integer",
        "description": "Total bytes to download (if known)"
      },
      "downloaded_bytes": {
        "type": "integer",
        "description": "Bytes downloaded so far"
      },
      "progress": {
        "type": "number",
        "description": "Download progress as a percentage (0.0 to 1.0)"
      },
      "speed_bps": {
        "type": "number",
        "description": "Download speed in bytes per second"
      },
      "eta_seconds": {
        "type": "integer",
        "description": "Estimated time remaining in seconds"
      },
      "error_message": {
        "type": "string",
        "description": "Error message if download/load failed"
      },
      "started_at": {
        "type": "string",
        "format": "date-time",
        "description": "When the download/operation started (ISO 8601)"
      },
      "finished_at": {
        "type": "string",
        "format": "date-time",
        "description": "When the download/operation completed or failed (ISO 8601)"
      },
      "local_path": {
        "type": "string",
        "description": "Local filesystem path if model is available locally"
      }
    }
  }
}