{
  "urn": "media:model-list;textable;record",
  "media_type": "application/json",
  "title": "Model List",
  "profile_uri": "https://capdag.com/schema/model-list",
  "description": "List of available models with their metadata and status",
  "schema": {
    "type": "object",
    "required": [
      "models"
    ],
    "properties": {
      "models": {
        "type": "array",
        "description": "List of model entries",
        "items": {
          "type": "object",
          "properties": {
            "model_spec": {
              "type": "string",
              "description": "Model specification string (e.g., 'hf:org/model-name')"
            },
            "name": {
              "type": "string",
              "description": "Human-readable model name"
            },
            "repository": {
              "type": "string",
              "description": "Repository source"
            },
            "local_available": {
              "type": "boolean",
              "description": "Whether the model is available locally"
            },
            "remote_available": {
              "type": "boolean",
              "description": "Whether the model is available remotely"
            },
            "local_path": {
              "type": "string",
              "description": "Local path if available"
            },
            "size_bytes": {
              "type": "integer",
              "description": "Total size in bytes"
            }
          }
        }
      },
      "count": {
        "type": "integer",
        "description": "Total number of models in the list"
      },
      "filter": {
        "type": "string",
        "description": "Filter pattern used if any"
      }
    }
  }
}