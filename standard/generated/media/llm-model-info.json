{
  "urn": "media:llm-model-info;json;record",
  "media_type": "application/json",
  "title": "LLM Model Info",
  "profile_uri": "https://capdag.com/schema/llm-model-info",
  "description": "Information about a loaded LLM model including capabilities and parameters",
  "schema": {
    "type": "object",
    "required": [
      "model_spec",
      "vocab_size"
    ],
    "properties": {
      "model_spec": {
        "type": "string",
        "description": "Model specification identifier"
      },
      "vocab_size": {
        "type": "integer",
        "description": "Size of the model's vocabulary"
      },
      "context_length": {
        "type": "integer",
        "description": "Maximum context length the model supports"
      },
      "embedding_dim": {
        "type": "integer",
        "description": "Dimension of embedding vectors"
      },
      "file_size_bytes": {
        "type": "integer",
        "description": "Model file size in bytes"
      },
      "head_count": {
        "type": "integer",
        "description": "Number of attention heads"
      },
      "layer_count": {
        "type": "integer",
        "description": "Number of transformer layers"
      },
      "supports_chat": {
        "type": "boolean",
        "description": "Whether the model has a chat template"
      },
      "supports_tools": {
        "type": "boolean",
        "description": "Whether the model supports tool use"
      }
    }
  }
}