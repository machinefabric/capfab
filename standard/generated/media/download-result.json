{
  "urn": "media:download-result;textable;record",
  "media_type": "application/json",
  "title": "Model Download Result",
  "profile_uri": "https://capdag.com/schema/download-result",
  "description": "Result from a model download operation, including the local path and download metadata",
  "schema": {
    "type": "object",
    "required": [
      "path",
      "success"
    ],
    "properties": {
      "success": {
        "type": "boolean",
        "description": "Whether the download completed successfully"
      },
      "path": {
        "type": "string",
        "description": "Local filesystem path where the model was downloaded"
      },
      "model_spec": {
        "type": "string",
        "description": "The model specification that was downloaded (e.g., 'hf:org/model-name')"
      },
      "total_bytes": {
        "type": "integer",
        "description": "Total bytes downloaded"
      },
      "file_count": {
        "type": "integer",
        "description": "Number of files downloaded"
      },
      "duration_ms": {
        "type": "integer",
        "description": "Download duration in milliseconds"
      },
      "error": {
        "type": "string",
        "description": "Error message if download failed"
      }
    }
  }
}